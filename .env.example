MUSIC_OS_HOST=127.0.0.1
MUSIC_OS_PORT=47831
MUSIC_OS_DATABASE_PATH=apps/backend/.music-os/music-os.sqlite
MUSIC_OS_MPV_PATH=/mnt/c/Program Files/mpv-x86_64-20181002/mpv.exe
MUSIC_OS_MUSICBRAINZ_ENABLED=1
MUSIC_OS_MUSICBRAINZ_USER_AGENT=MusicOS/0.1.0 (local-dev)
# Optional Chromaprint support. Install fpcalc and set this path to store acoustic fingerprints during import.
# MUSIC_OS_FPCALC_PATH=/usr/bin/fpcalc
# Optional hosted model planning for agent runs. Tool execution and approvals stay local.
# MUSIC_OS_AGENT_MODEL_PROVIDER=local
# MUSIC_OS_AGENT_MODEL_PROVIDER=openai
# OPENAI_API_KEY=replace_with_openai_api_key
# MUSIC_OS_OPENAI_MODEL=gpt-5.5
# Set to 0 to disable OpenAI-hosted web research for playlist/recommendation planning.
# MUSIC_OS_AGENT_WEB_RESEARCH=1
# Set to 0 to keep researched playlist download/import workflows review-only.
# MUSIC_OS_AGENT_AUTO_START_RESEARCH_PLAYLISTS=1
# Background retry interval for agent playlist workflows that are waiting on downloads/imports.
# MUSIC_OS_AGENT_PLAYLIST_WORKFLOW_ADVANCE_MS=15000
# Optional paid live smoke for the hosted planner. Leave unset during normal test runs.
# MUSIC_OS_LIVE_OPENAI_AGENT_SMOKE=1

# slskd runs on Windows. From WSL, use the Windows host IP from:
# awk '/nameserver/ {print $2; exit}' /etc/resolv.conf
MUSIC_OS_SLSKD_URL=http://172.21.0.1:5030
MUSIC_OS_SLSKD_API_KEY=replace_with_slskd_api_key
# WSL-readable folder where slskd writes completed downloads.
MUSIC_OS_SLSKD_DOWNLOAD_DIR=/mnt/d/Downloads/slskd-downloads
# Optional fallback if API key auth is not used.
# MUSIC_OS_SLSKD_USERNAME=slskd
# MUSIC_OS_SLSKD_PASSWORD=replace_with_slskd_web_password
# Optional search reliability tuning. slskd itself should also have its Soulseek
# listen port reachable/forwarded; otherwise search results can be poor.
# MUSIC_OS_SLSKD_SEARCH_ATTEMPTS=2
# MUSIC_OS_SLSKD_SEARCH_RETRY_DELAY_MS=750
# MUSIC_OS_SLSKD_SEARCH_TIMEOUT_MS=30000
# MUSIC_OS_SLSKD_SEARCH_GRACE_MS=8000
# MUSIC_OS_SLSKD_SEARCH_COMPLETED_EMPTY_GRACE_MS=5000
# MUSIC_OS_SLSKD_SEARCH_PARTIAL_AFTER_MS=4000
# MUSIC_OS_SLSKD_SEARCH_FILE_LIMIT=10000
# MUSIC_OS_SLSKD_SEARCH_FILTER_RESPONSES=1
# Comma-separated artist/search tokens to strip on empty-result fallback searches.
# MUSIC_OS_SLSKD_SUPPRESSED_SEARCH_TERMS=the beatles,beatles,le sserafim,sserafim

# Optional: enables cached waveform generation and live visualizer sidecar analysis.
# MUSIC_OS_FFMPEG_PATH=/usr/bin/ffmpeg
