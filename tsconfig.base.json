{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@music-os/core": ["packages/core/src/index.ts"],
      "@music-os/db": ["packages/db/src/index.ts"],
      "@music-os/playback": ["packages/playback/src/index.ts"],
      "@music-os/connectors": ["packages/connectors/src/index.ts"],
      "@music-os/operations": ["packages/operations/src/index.ts"]
    }
  }
}
